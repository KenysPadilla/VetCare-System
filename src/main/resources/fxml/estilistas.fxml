<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane style="-fx-background-color: #F0F4F0;" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/21" fx:controller="controlador.EstilistasControlador">

    <VBox spacing="15" AnchorPane.topAnchor="10" AnchorPane.bottomAnchor="10" AnchorPane.leftAnchor="10" AnchorPane.rightAnchor="10">

        <Label text="Gestión de Estilistas" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1B6B2F;" />

        <HBox spacing="10" alignment="CENTER_LEFT">
            <TextField fx:id="txtBuscar" prefWidth="300" prefHeight="35" promptText="Buscar por nombre o especialidad" style="-fx-border-color: #D6EAD8; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 6;" />
            <Button onAction="#handleBuscar" text="Buscar" prefHeight="35" style="-fx-background-color: #1B6B2F; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6; -fx-cursor: hand;" />
        </HBox>

        <TableView fx:id="tablaEstilistas" VBox.vgrow="ALWAYS" style="-fx-background-color: white;">
            <columns>
                <TableColumn fx:id="colCedula" text="Cédula" prefWidth="120" />
                <TableColumn fx:id="colNombre" text="Nombre" prefWidth="140" />
                <TableColumn fx:id="colApellido" text="Apellido" prefWidth="140" />
                <TableColumn fx:id="colEspecialidad" text="Especialidad Estética" prefWidth="180" />
                <TableColumn fx:id="colTelefono" text="Teléfono" prefWidth="120" />
                <TableColumn fx:id="colCorreo" text="Correo" prefWidth="180" />
            </columns>
        </TableView>

        <HBox spacing="10" alignment="CENTER_LEFT">
            <Button onAction="#handleNuevo" text="Nuevo Estilista" prefHeight="38" prefWidth="160" style="-fx-background-color: #1B6B2F; -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold; -fx-background-radius: 6; -fx-cursor: hand;" />
            <Button onAction="#handleEditar" text="Editar" prefHeight="38" prefWidth="120" style="-fx-background-color: white; -fx-text-fill: #1B6B2F; -fx-font-size: 13px; -fx-border-color: #1B6B2F; -fx-border-radius: 6; -fx-background-radius: 6; -fx-cursor: hand;" />
            <Button onAction="#handleEliminar" text="Eliminar" prefHeight="38" prefWidth="120" style="-fx-background-color: white; -fx-text-fill: #D32F2F; -fx-font-size: 13px; -fx-border-color: #D32F2F; -fx-border-radius: 6; -fx-background-radius: 6; -fx-cursor: hand;" />
        </HBox>

    </VBox>

</AnchorPane>
