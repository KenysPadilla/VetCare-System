<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="600" prefWidth="900" style="-fx-background-color: #f0f4f0;" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/25" fx:controller="controlador.LoginControlador">

    <!-- Panel izquierdo verde -->
    <VBox alignment="CENTER" prefHeight="600" prefWidth="450" spacing="20" style="-fx-background-color: #1B6B2F;" AnchorPane.leftAnchor="0" AnchorPane.topAnchor="0">

        <Label style="-fx-font-size: 60px;" text="🐾" />
        <Label style="-fx-font-size: 32px; -fx-font-weight: bold;                        -fx-text-fill: white;" text="VetCare System" />
        <Label style="-fx-font-size: 16px; -fx-text-fill: #D6EAD8;" text="Management Console" />
        <Label alignment="CENTER" maxWidth="300" style="-fx-font-size: 13px; -fx-text-fill: #D6EAD8;                       -fx-wrap-text: true; -fx-text-alignment: center;" text="Gestión Integral de Clínica Veterinaria" />
    </VBox>

    <!-- Panel derecho blanco -->
    <VBox alignment="CENTER" prefHeight="600" prefWidth="450" spacing="20" style="-fx-background-color: white;" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0">

        <Label style="-fx-font-size: 26px; -fx-font-weight: bold;                        -fx-text-fill: #1B6B2F;" text="Iniciar Sesión" />
        <Label style="-fx-font-size: 13px; -fx-text-fill: #666666;" text="ingresar usuario y contraseña " />

        <VBox maxWidth="320" spacing="8">
            <Label style="-fx-font-weight: bold; -fx-text-fill: #333333;" text="Usuario" />
            <TextField fx:id="txtUsuario" prefHeight="40" promptText="Ingresa tu usuario" style="-fx-border-color: #D6EAD8;                                -fx-border-radius: 6;                                -fx-background-radius: 6;                               -fx-padding: 8;" />
        </VBox>

        <VBox maxWidth="320" spacing="8">
            <Label style="-fx-font-weight: bold; -fx-text-fill: #333333;" text="Contraseña" />
            <PasswordField fx:id="txtPassword" prefHeight="40" promptText="Ingresa tu contraseña" style="-fx-border-color: #D6EAD8;                                    -fx-border-radius: 6;                                    -fx-background-radius: 6;                                   -fx-padding: 8;" />
        </VBox>

        <VBox alignment="CENTER" maxWidth="320" spacing="5">
            <Hyperlink style="-fx-text-fill: #1B6B2F;                                -fx-font-size: 12px;" text="¿Olvidaste tu contraseña?" />
        </VBox>

        <VBox maxWidth="320" spacing="15">
            <Button fx:id="btnLogin" onAction="#handleLogin" prefHeight="45" prefWidth="320" style="-fx-background-color: #1B6B2F;                             -fx-text-fill: white;                             -fx-font-size: 14px;                            -fx-font-weight: bold;                            -fx-background-radius: 6;                            -fx-cursor: hand;" text="Iniciar Sesión" />

            <Label fx:id="lblError" style="-fx-text-fill: red;                            -fx-font-size: 12px;" text="" />
        </VBox>

    </VBox>

</AnchorPane>
