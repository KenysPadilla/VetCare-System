<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="500" prefWidth="500" style="-fx-background-color: white;" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/21" fx:controller="controlador.NuevaCitaControlador">

    <VBox spacing="15" AnchorPane.topAnchor="20" AnchorPane.bottomAnchor="20" AnchorPane.leftAnchor="30" AnchorPane.rightAnchor="30">

        <Label text="Nueva Cita Médica" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1B6B2F;" />

        <VBox spacing="6">
            <Label text="Paciente" style="-fx-font-weight: bold; -fx-text-fill: #333333;" />
            <ComboBox fx:id="cbPaciente" prefWidth="440" promptText="Seleccionar paciente" style="-fx-border-color: #D6EAD8; -fx-border-radius: 6; -fx-background-radius: 6;" />
        </VBox>

        <VBox spacing="6">
            <Label text="Veterinario" style="-fx-font-weight: bold; -fx-text-fill: #333333;" />
            <ComboBox fx:id="cbVeterinario" prefWidth="440" promptText="Seleccionar veterinario" style="-fx-border-color: #D6EAD8; -fx-border-radius: 6; -fx-background-radius: 6;" />
        </VBox>

        <HBox spacing="15">
            <VBox spacing="6">
                <Label text="Fecha" style="-fx-font-weight: bold; -fx-text-fill: #333333;" />
                <DatePicker fx:id="dpFecha" prefWidth="210" />
            </VBox>
            <VBox spacing="6">
                <Label text="Hora" style="-fx-font-weight: bold; -fx-text-fill: #333333;" />
                <ComboBox fx:id="cbHora" prefWidth="210" promptText="Seleccionar hora" />
            </VBox>
        </HBox>

        <VBox spacing="6">
            <Label text="Tipo de Cita" style="-fx-font-weight: bold; -fx-text-fill: #333333;" />
            <ComboBox fx:id="cbTipo" prefWidth="440" promptText="Seleccionar tipo" style="-fx-border-color: #D6EAD8; -fx-border-radius: 6; -fx-background-radius: 6;" />
        </VBox>

        <VBox spacing="6">
            <Label text="Motivo" style="-fx-font-weight: bold; -fx-text-fill: #333333;" />
            <TextArea fx:id="txtMotivo" prefHeight="80" promptText="Describa el motivo de la cita" style="-fx-border-color: #D6EAD8; -fx-border-radius: 6; -fx-background-radius: 6;" />
        </VBox>

        <Label fx:id="lblMensaje" text="" style="-fx-font-size: 12px;" />

        <HBox spacing="10" alignment="CENTER_RIGHT">
            <Button fx:id="btnGuardar" onAction="#handleGuardar" text="Guardar" prefHeight="40" prefWidth="140" style="-fx-background-color: #1B6B2F; -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold; -fx-background-radius: 6; -fx-cursor: hand;" />
            <Button fx:id="btnCancelar" onAction="#handleCancelar" text="Cancelar" prefHeight="40" prefWidth="140" style="-fx-background-color: white; -fx-text-fill: #D32F2F; -fx-font-size: 13px; -fx-border-color: #D32F2F; -fx-border-radius: 6; -fx-background-radius: 6; -fx-cursor: hand;" />
        </HBox>

    </VBox>

</AnchorPane>
