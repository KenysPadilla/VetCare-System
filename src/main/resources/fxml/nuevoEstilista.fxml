<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="420" prefWidth="450" style="-fx-background-color: white;" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/21" fx:controller="controlador.NuevoEstilistaControlador">

    <VBox spacing="12" AnchorPane.topAnchor="20" AnchorPane.bottomAnchor="20" AnchorPane.leftAnchor="30" AnchorPane.rightAnchor="30">

        <Label text="Nuevo Estilista" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1B6B2F;" />

        <VBox spacing="5">
            <Label text="Cédula" style="-fx-font-weight: bold; -fx-text-fill: #333333;" />
            <TextField fx:id="txtCedula" prefHeight="35" promptText="Número de cédula" style="-fx-border-color: #D6EAD8; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 6;" />
        </VBox>

        <VBox spacing="5">
            <Label text="Nombre" style="-fx-font-weight: bold; -fx-text-fill: #333333;" />
            <TextField fx:id="txtNombre" prefHeight="35" promptText="Nombre(s)" style="-fx-border-color: #D6EAD8; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 6;" />
        </VBox>

        <VBox spacing="5">
            <Label text="Apellido" style="-fx-font-weight: bold; -fx-text-fill: #333333;" />
            <TextField fx:id="txtApellido" prefHeight="35" promptText="Apellido(s)" style="-fx-border-color: #D6EAD8; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 6;" />
        </VBox>

        <VBox spacing="5">
            <Label text="Especialidad Estética" style="-fx-font-weight: bold; -fx-text-fill: #333333;" />
            <ComboBox fx:id="cbEspecialidad" prefWidth="390" promptText="Seleccionar" style="-fx-border-color: #D6EAD8; -fx-border-radius: 6; -fx-background-radius: 6;" />
        </VBox>

        <VBox spacing="5">
            <Label text="Teléfono" style="-fx-font-weight: bold; -fx-text-fill: #333333;" />
            <TextField fx:id="txtTelefono" prefHeight="35" promptText="Número de contacto" style="-fx-border-color: #D6EAD8; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 6;" />
        </VBox>

        <VBox spacing="5">
            <Label text="Correo" style="-fx-font-weight: bold; -fx-text-fill: #333333;" />
            <TextField fx:id="txtCorreo" prefHeight="35" promptText="correo@ejemplo.com" style="-fx-border-color: #D6EAD8; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 6;" />
        </VBox>

        <Label fx:id="lblMensaje" text="" style="-fx-font-size: 12px;" />

        <HBox spacing="10" alignment="CENTER_RIGHT">
            <Button onAction="#handleGuardar" text="Guardar" prefHeight="40" prefWidth="140" style="-fx-background-color: #1B6B2F; -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold; -fx-background-radius: 6; -fx-cursor: hand;" />
            <Button onAction="#handleCancelar" text="Cancelar" prefHeight="40" prefWidth="140" style="-fx-background-color: white; -fx-text-fill: #D32F2F; -fx-font-size: 13px; -fx-border-color: #D32F2F; -fx-border-radius: 6; -fx-background-radius: 6; -fx-cursor: hand;" />
        </HBox>

    </VBox>

</AnchorPane>
