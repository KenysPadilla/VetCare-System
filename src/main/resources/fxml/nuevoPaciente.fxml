<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="520" prefWidth="450" style="-fx-background-color: white;" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/21" fx:controller="controlador.NuevoPacienteControlador">

    <VBox spacing="12" AnchorPane.topAnchor="20" AnchorPane.bottomAnchor="20" AnchorPane.leftAnchor="30" AnchorPane.rightAnchor="30">

        <Label text="Nuevo Paciente" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1B6B2F;" />

        <VBox spacing="5">
            <Label text="Propietario" style="-fx-font-weight: bold; -fx-text-fill: #333333;" />
            <ComboBox fx:id="cbPropietario" prefWidth="390" promptText="Seleccionar propietario" style="-fx-border-color: #D6EAD8; -fx-border-radius: 6; -fx-background-radius: 6;" />
        </VBox>

        <VBox spacing="5">
            <Label text="Nombre del animal" style="-fx-font-weight: bold; -fx-text-fill: #333333;" />
            <TextField fx:id="txtNombre" prefHeight="35" promptText="Nombre de la mascota" style="-fx-border-color: #D6EAD8; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 6;" />
        </VBox>

        <HBox spacing="15">
            <VBox spacing="5">
                <Label text="Especie" style="-fx-font-weight: bold; -fx-text-fill: #333333;" />
                <ComboBox fx:id="cbEspecie" prefWidth="185" promptText="Seleccionar" style="-fx-border-color: #D6EAD8; -fx-border-radius: 6; -fx-background-radius: 6;" />
            </VBox>
            <VBox spacing="5">
                <Label text="Raza" style="-fx-font-weight: bold; -fx-text-fill: #333333;" />
                <TextField fx:id="txtRaza" prefHeight="35" prefWidth="185" promptText="Raza" style="-fx-border-color: #D6EAD8; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 6;" />
            </VBox>
        </HBox>

        <HBox spacing="15">
            <VBox spacing="5">
                <Label text="Sexo" style="-fx-font-weight: bold; -fx-text-fill: #333333;" />
                <ComboBox fx:id="cbSexo" prefWidth="185" promptText="Seleccionar" style="-fx-border-color: #D6EAD8; -fx-border-radius: 6; -fx-background-radius: 6;" />
            </VBox>
            <VBox spacing="5">
                <Label text="Peso (kg)" style="-fx-font-weight: bold; -fx-text-fill: #333333;" />
                <TextField fx:id="txtPeso" prefHeight="35" prefWidth="185" promptText="Ej: 12.5" style="-fx-border-color: #D6EAD8; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 6;" />
            </VBox>
        </HBox>

        <HBox spacing="15">
            <VBox spacing="5">
                <Label text="Fecha de nacimiento" style="-fx-font-weight: bold; -fx-text-fill: #333333;" />
                <DatePicker fx:id="dpFechaNacimiento" prefWidth="185" />
            </VBox>
            <VBox spacing="5">
                <Label text="Microchip" style="-fx-font-weight: bold; -fx-text-fill: #333333;" />
                <TextField fx:id="txtMicrochip" prefHeight="35" prefWidth="185" promptText="Código microchip" style="-fx-border-color: #D6EAD8; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 6;" />
            </VBox>
        </HBox>

        <Label fx:id="lblMensaje" text="" style="-fx-font-size: 12px;" />

        <HBox spacing="10" alignment="CENTER_RIGHT">
            <Button onAction="#handleGuardar" text="Guardar" prefHeight="40" prefWidth="140" style="-fx-background-color: #1B6B2F; -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold; -fx-background-radius: 6; -fx-cursor: hand;" />
            <Button onAction="#handleCancelar" text="Cancelar" prefHeight="40" prefWidth="140" style="-fx-background-color: white; -fx-text-fill: #D32F2F; -fx-font-size: 13px; -fx-border-color: #D32F2F; -fx-border-radius: 6; -fx-background-radius: 6; -fx-cursor: hand;" />
        </HBox>

    </VBox>

</AnchorPane>
