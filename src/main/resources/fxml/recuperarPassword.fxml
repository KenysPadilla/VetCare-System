<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="600" prefWidth="900" style="-fx-background-color: #f0f4f0;" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/25" fx:controller="controlador.RecuperarPasswordControlador">

    <!-- Panel izquierdo verde -->
    <VBox alignment="CENTER" prefHeight="600" prefWidth="450" spacing="20" style="-fx-background-color: #1B6B2F;" AnchorPane.leftAnchor="0" AnchorPane.topAnchor="0">

        <Label style="-fx-font-size: 60px;" text="🔐" />
        <Label style="-fx-font-size: 32px; -fx-font-weight: bold;                       -fx-text-fill: white;" text="VetCare System" />
        <Label style="-fx-font-size: 16px; -fx-text-fill: #D6EAD8;" text="Recuperar Contraseña" />
        <Label maxWidth="300" style="-fx-font-size: 13px; -fx-text-fill: #D6EAD8;                       -fx-wrap-text: true; -fx-text-alignment: center;" text="Te enviaremos tu contraseñal por mensaje de texto" />
    </VBox>

    <!-- Panel derecho blanco -->
    <VBox alignment="CENTER" prefHeight="600" prefWidth="450" spacing="20" style="-fx-background-color: white;" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0">

        <Label style="-fx-font-size: 26px; -fx-font-weight: bold;                       -fx-text-fill: #1B6B2F;" text="Recuperar Contraseña" />
        <Label style="-fx-font-size: 13px; -fx-text-fill: #666666;" text="Ingresa tu usuario y número de teléfono" />

        <VBox maxWidth="320" spacing="8">
            <Label style="-fx-font-weight: bold; -fx-text-fill: #333333;" text="Usuario" />
            <TextField fx:id="txtUsuario" prefHeight="40" promptText="Ingresa tu usuario" style="-fx-border-color: #D6EAD8;                               -fx-border-radius: 6;                               -fx-background-radius: 6;                               -fx-padding: 8;" />
        </VBox>

        <VBox maxWidth="320" spacing="8">
            <Label style="-fx-font-weight: bold; -fx-text-fill: #333333;" text="Número de Teléfono" />
            <TextField fx:id="txtTelefono" prefHeight="40" promptText="Ej: 3001234567" style="-fx-border-color: #D6EAD8;                               -fx-border-radius: 6;                               -fx-background-radius: 6;                               -fx-padding: 8;" />
        </VBox>

        <VBox maxWidth="320" spacing="10">
            <Button fx:id="btnEnviar" onAction="#handleEnviar" prefHeight="45" prefWidth="320" style="-fx-background-color: #1B6B2F;                            -fx-text-fill: white;                            -fx-font-size: 14px;                            -fx-font-weight: bold;                            -fx-background-radius: 6;                            -fx-cursor: hand;" text="Enviar Contraseña por SMS" />

            <Button fx:id="btnVolver" onAction="#handleVolver" prefHeight="40" prefWidth="320" style="-fx-background-color: transparent;                            -fx-text-fill: #1B6B2F;                            -fx-font-size: 13px;                            -fx-border-color: #1B6B2F;                            -fx-border-radius: 6;                            -fx-background-radius: 6;                            -fx-cursor: hand;" text="← Volver al Login" />
        </VBox>

        <Label fx:id="lblMensaje" style="-fx-text-fill: #1B6B2F; -fx-font-size: 12px;" text="" />

    </VBox>

</AnchorPane>
