<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<AnchorPane style="-fx-background-color: #f0f4f0;"
            prefWidth="900" prefHeight="600"
            xmlns:fx="http://javafx.com/fxml">

    <!-- Panel izquierdo verde -->
    <VBox prefWidth="450" prefHeight="600"
          style="-fx-background-color: #1B6B2F;"
          alignment="CENTER" spacing="20"
          AnchorPane.leftAnchor="0" AnchorPane.topAnchor="0">

        <Label text="🔐"
               style="-fx-font-size: 60px;"/>
        <Label text="VetCare System"
               style="-fx-font-size: 32px; -fx-font-weight: bold;
                      -fx-text-fill: white;"/>
        <Label text="Recuperar Contraseña"
               style="-fx-font-size: 16px; -fx-text-fill: #D6EAD8;"/>
        <Label text="Te enviaremos tu contraseña actual por mensaje de texto"
               style="-fx-font-size: 13px; -fx-text-fill: #D6EAD8;
                      -fx-wrap-text: true; -fx-text-alignment: center;"
               maxWidth="300"/>
    </VBox>

    <!-- Panel derecho blanco -->
    <VBox prefWidth="450" prefHeight="600"
          style="-fx-background-color: white;"
          alignment="CENTER" spacing="20"
          AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0">

        <Label text="Recuperar Contraseña"
               style="-fx-font-size: 26px; -fx-font-weight: bold;
                      -fx-text-fill: #1B6B2F;"/>
        <Label text="Ingresa tu usuario y número de teléfono"
               style="-fx-font-size: 13px; -fx-text-fill: #666666;"/>

        <VBox spacing="8" maxWidth="320">
            <Label text="Usuario"
                   style="-fx-font-weight: bold; -fx-text-fill: #333333;"/>
            <TextField fx:id="txtUsuario"
                       promptText="Ingresa tu usuario"
                       prefHeight="40"
                       style="-fx-border-color: #D6EAD8;
                              -fx-border-radius: 6;
                              -fx-background-radius: 6;
                              -fx-padding: 8;"/>
        </VBox>

        <VBox spacing="8" maxWidth="320">
            <Label text="Número de Teléfono"
                   style="-fx-font-weight: bold; -fx-text-fill: #333333;"/>
            <TextField fx:id="txtTelefono"
                       promptText="Ej: 3001234567"
                       prefHeight="40"
                       style="-fx-border-color: #D6EAD8;
                              -fx-border-radius: 6;
                              -fx-background-radius: 6;
                              -fx-padding: 8;"/>
        </VBox>

        <VBox spacing="10" maxWidth="320">
            <Button fx:id="btnEnviar"
                    text="Enviar Contraseña por SMS"
                    prefWidth="320" prefHeight="45"
                    style="-fx-background-color: #1B6B2F;
                           -fx-text-fill: white;
                           -fx-font-size: 14px;
                           -fx-font-weight: bold;
                           -fx-background-radius: 6;
                           -fx-cursor: hand;"/>

            <Button fx:id="btnVolver"
                    text="← Volver al Login"
                    prefWidth="320" prefHeight="40"
                    style="-fx-background-color: transparent;
                           -fx-text-fill: #1B6B2F;
                           -fx-font-size: 13px;
                           -fx-border-color: #1B6B2F;
                           -fx-border-radius: 6;
                           -fx-background-radius: 6;
                           -fx-cursor: hand;"/>
        </VBox>

        <Label fx:id="lblMensaje" text=""
               style="-fx-text-fill: #1B6B2F; -fx-font-size: 12px;"/>

    </VBox>

</AnchorPane>
